generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  name      String     @default("Admin")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  chatbots  Chatbot[]
}

model Chatbot {
  id             String   @id @default(uuid())
  name           String   @default("My Chatbot")
  businessName   String   @default("")
  businessInfo   String   @default("") @db.Text
  systemPrompt   String   @default("You are a helpful assistant.") @db.Text
  welcomeMessage String   @default("Hello! How can I help you today?")
  primaryColor   String   @default("#6366f1")
  position       String   @default("bottom-right")
  knowledgeMode  String   @default("simple")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  adminId       String
  admin         Admin          @relation(fields: [adminId], references: [id], onDelete: Cascade)
  apiConfig     ApiConfig?
  knowledgeBase KnowledgeBase?
  conversations Conversation[]

  @@index([adminId])
}

model ApiConfig {
  id          String   @id @default(uuid())
  provider    String   @default("openai")
  apiKey      String   @default("") @db.Text
  model       String   @default("gpt-3.5-turbo")
  baseUrl     String   @default("")
  maxTokens   Int      @default(1024)
  temperature Float    @default(0.7)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chatbotId String  @unique
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
}

model Conversation {
  id          String   @id @default(uuid())
  sessionId   String
  visitorIp   String   @default("")
  visitorName String   @default("Visitor")
  pageUrl     String   @default("")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chatbotId String
  chatbot   Chatbot   @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([sessionId])
  @@index([chatbotId])
  @@index([createdAt])
}

model Message {
  id             String   @id @default(uuid())
  role           String
  content        String   @db.Text
  tokenCount     Int      @default(0)
  responseTimeMs Int      @default(0)
  createdAt      DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@index([role])
}

model KnowledgeBase {
  id                  String   @id @default(uuid())
  name                String   @default("Knowledge Base")
  description         String   @default("") @db.Text
  status              String   @default("active")
  chunkSize           Int      @default(600)
  chunkOverlap        Int      @default(100)
  totalChunks         Int      @default(0)
  totalTokens         Int      @default(0)
  embeddingProvider   String   @default("openai")
  embeddingModel      String   @default("text-embedding-3-small")
  embeddingApiKey     String   @default("") @db.Text
  embeddingBaseUrl    String   @default("")
  embeddingDimensions Int      @default(1536)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  chatbotId String  @unique
  chatbot   Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)
  documents Document[]

  @@index([chatbotId])
}

model Document {
  id            String   @id @default(uuid())
  filename      String
  originalName  String   @default("")
  mimeType      String   @default("text/plain")
  fileSize      Int      @default(0)
  sourceType    String   @default("file")
  sourceUrl     String   @default("")
  status        String   @default("pending")
  errorMessage  String   @default("") @db.Text
  chunkCount    Int      @default(0)
  tokenCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  knowledgeBaseId String
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  chunks          DocumentChunk[]

  @@index([knowledgeBaseId])
  @@index([status])
}

model DocumentChunk {
  id         String   @id @default(uuid())
  content    String   @db.Text
  tokenCount Int      @default(0)
  chunkIndex Int      @default(0)
  metadata   Json     @default("{}")
  embedding  Unsupported("vector(1536)")
  createdAt  DateTime @default(now())

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}
